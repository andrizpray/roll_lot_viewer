APP_NAME="Roll Lot Viewer"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# API key for protecting API endpoints (required in production)
API_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_DATABASE defaults to database/database.sqlite (relative to project root)

QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
